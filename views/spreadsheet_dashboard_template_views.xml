<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Template Kanban View -->
    <record id="view_spreadsheet_dashboard_template_kanban" model="ir.ui.view">
        <field name="name">spreadsheet.dashboard.template.kanban</field>
        <field name="model">spreadsheet.dashboard.template</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard" create="1" sample="1">
                <field name="name"/>
                <field name="description"/>
                <field name="preview_image"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click d-flex flex-column">
                            <div class="o_kanban_image mb-2">
                                <img t-att-src="kanban_image('spreadsheet.dashboard.template', 'preview_image', record.id.raw_value)" alt="Template Preview" class="img-fluid rounded"/>
                            </div>
                            <div class="oe_kanban_details text-center">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div class="text-muted mt-1"><field name="description"/></div>
                            </div>
                            <div class="mt-3 text-center">
                                <button type="object" name="action_instantiate_dashboard" class="btn btn-primary btn-sm">
                                    Utiliser ce modèle
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Template Form View -->
    <record id="view_spreadsheet_dashboard_template_form" model="ir.ui.view">
        <field name="name">spreadsheet.dashboard.template.form</field>
        <field name="model">spreadsheet.dashboard.template</field>
        <field name="arch" type="xml">
            <form string="Dashboard Template">
                <header>
                    <button name="action_instantiate_dashboard" string="Utiliser ce modèle" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <field name="preview_image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="E.g., Sales Overview"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="dashboard_group_id"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Describe the purpose of this dashboard template..."/>
                        </page>
                        <page string="Spreadsheet Data" groups="base.group_no_one">
                            <field name="raw_data" filename="raw_data_filename"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_spreadsheet_dashboard_template" model="ir.actions.act_window">
        <field name="name">Dashboard Templates</field>
        <field name="res_model">spreadsheet.dashboard.template</field>
        <field name="view_mode">kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez vos modèles de Tableaux de Bord Odoo Spreadsheet.
            </p>
        </field>
    </record>

    <!-- Menu Item in Spreadsheet -->
    <menuitem id="menu_spreadsheet_dashboard_template"
              name="Modèles"
              parent="spreadsheet_dashboard.spreadsheet_dashboard_menu_configuration"
              action="action_spreadsheet_dashboard_template"
              sequence="20"/>
</odoo>
